<html>
<head>
<meta http-equiv="x-ua-compatible" content="ie=edge">
<title>Windows Security Center</title>
<hta:application
    id="oPrank"
    border="thin"
    caption="yes"
    showintaskbar="yes"
    singleinstance="yes"
    sysmenu="yes"
    windowstate="normal"
    scroll="no"
    maximizebutton="no"
    minimizebutton="no"
>

<style>
    /* 1. ALLOW CONTENT TO FILL THE WINDOW AUTOMATICALLY */
    html, body {
        width: 100%;
        height: 100%;
        margin: 0;
        padding: 0;
        background-color: #f0f0f0;
        font-family: 'Segoe UI', Tahoma, sans-serif;
        overflow: hidden;
    }

    /* 2. ADJUST PADDING TO ACCOUNT FOR BORDERS */
    #wrapper {
        width: 100%;
        height: 100%;
        position: relative;
        padding: 30px;
        box-sizing: border-box;
    }

    .progress-container {
        width: 100%;
        background-color: #ddd;
        border-radius: 5px;
        margin: 20px 0;
        height: 30px;
        display: none;
        overflow: hidden;
    }
    .progress-bar {
        width: 0%;
        height: 100%;
        background-color: #0078d4;
        border-radius: 5px;
        transition: width 0.2s ease-in-out;
    }

    .btn-row {
        position: absolute;
        bottom: 30px;
        right: 30px;
    }

    button {
        padding: 10px 20px;
        margin-left: 10px;
        cursor: pointer;
        font-weight: bold;
    }

    .btn-primary { background: #0078d4; color: white; border: none; }
    .btn-secondary { background: #e1e1e1; border: 1px solid #adadad; }

    .dark-mode { background-color: #1a1a1a !important; color: white !important; }
    .card {
        background: #2d2d2d;
        padding: 20px;
        border-radius: 10px;
        border: 2px solid #d9534f;
        text-align: center;
    }
</style>

<script type="text/javascript">
    window.progressCounter = 0;

    window.init = function() {
        try {
            window.resizeTo(550, 500);
            window.moveTo((screen.width - 550) / 2, (screen.height - 500) / 2);
        } catch (e) { }
    };

    window.StartScan = function() {
        document.getElementById("initial_screen").style.display = "none";
        document.getElementById("scan_screen").style.display = "block";
        document.getElementById("p_bar_container").style.display = "block";
        window.progressCounter = 0;
        window.UpdateProgress();
    };

    window.UpdateProgress = function() {
        if (window.progressCounter <= 100) {
            document.getElementById("p_bar").style.width = window.progressCounter + "%";
            document.getElementById("status_text").innerText = "Scanning: C:\\Windows\\System32\\drivers\\file_" + (window.progressCounter * 7) + ".sys";
            window.progressCounter += 2;
            setTimeout(window.UpdateProgress, 100);
        } else {
            window.ShowError();
        }
    };

    window.ShowError = function() {
        document.getElementById("scan_screen").style.display = "none";
        document.getElementById("error_screen").style.display = "block";
    };

    window.DownloadPhase = function() {
        document.body.className = "dark-mode";
        document.getElementById("error_screen").style.display = "none";
        document.getElementById("destroyer_screen").style.display = "block";
    };

    window.RevealJoke = function() {
        document.getElementById("destroyer_screen").style.display = "none";
        document.getElementById("joke_screen").style.display = "block";
    };

    window.CloseApp = function() {
        try {
            var shell = new ActiveXObject("WScript.Shell");
            shell.Popup("Just a joke! Your PC is safe.", 0, "Security Update", 64);
        } catch (e) {
            alert("Just a joke! Your PC is safe.");
        }
        window.close();
    };
</script>
</head>
<body onload="window.init()">
<div id="wrapper">
    <div id="initial_screen">
        <h2 style="color:#d9534f;">⚠️ Security Alert</h2>
        <p>A high-risk exploit has been detected on this PC.</p>
        <p><b>Threat:</b> Trojan:Win32/ScriptPrank.A</p>
        <div class="btn-row">
            <button class="btn-secondary" onclick="window.CloseApp()">Cancel</button>
            <button class="btn-primary" onclick="window.StartScan()">Scan Now</button>
        </div>
    </div>

    <div id="scan_screen" style="display:none;">
        <h2>System Scan</h2>
        <p id="status_text">Initializing...</p>
        <div class="progress-container" id="p_bar_container">
            <div id="p_bar" class="progress-bar"></div>
        </div>
    </div>

    <div id="error_screen" style="display:none;">
        <h2 style="color:#d9534f;">❌ Scan Failed</h2>
        <p>The system was unable to remove the threat automatically.</p>
        <div class="btn-row">
            <button class="btn-secondary" onclick="window.CloseApp()">No</button>
            <button class="btn-primary" onclick="window.DownloadPhase()">Yes, Fix Now</button>
        </div>
    </div>

    <div id="destroyer_screen" style="display:none;">
        <div class="card">
            <h2 style="color:white;">Trojan Destroyer</h2>
            <p style="color:white;">Ready to scrub infected registry keys.</p>
            <button style="padding:15px; background:#d9534f; color:white; border:none;" onclick="window.RevealJoke()">DOWNLOAD NOW</button>
        </div>
    </div>

    <div id="joke_screen" style="display:none; text-align:center;">
        <h1 style="margin-top: 40px;">😜 JUST A JOKE!</h1>
        <p>No virus found. You've been pranked!</p>
        <img src="https://i.giphy.com/3o7TKVUn7iM8FMEU24.gif" width="200" style="border-radius: 10px; margin-bottom: 20px;">
        <div>
            <button class="btn-primary" style="background:#4CAF50; width: 200px; padding: 15px;" onclick="window.close()">Finish & Close</button>
        </div>
    </div>
</div>
</body>
</html>
